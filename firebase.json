{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/ads.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "!/@(ads.txt|*.html|*.js|*.css|*.json|*.png|*.jpg|*.ico)",
        "destination": "/index.html"
      }
    ]
  }
}